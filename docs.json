        "groups": [
          {
            "group": "Overview",
            "icon": "plug",
            "pages": ["integrations/index"]
          },
          {
            "group": "Development Tools",
            "icon": "code",
            "pages": [
              "integrations/claude-code",
              "integrations/cursor",
              "integrations/cline",
              "integrations/gemini-cli",
              "integrations/codex-cli"
            ]
          },
          {
            "group": "SDKs",
            "icon": "box",
            "pages": ["sdks/openai-python", "sdks/openai-node"]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": ["quickstart", "authentication"]
