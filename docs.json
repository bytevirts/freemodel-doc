            "icon": "book-open",
            "pages": ["index"]
          },
          {
            "group": "Text Series",
            "icon": "font",
            "pages": [
              "api-manual/text/gpt-5-4",
              "api-manual/text/gpt-5-4-mini",
              "api-manual/text/gpt-5-5",
              "api-manual/text/gpt-5-6",
              "api-manual/text/gpt-5-6-luna",
              "api-manual/text/gpt-5-6-sol",
              "api-manual/text/gpt-5-6-terra"
            ]
          },
          {
            "group": "Image Series",
            "icon": "image",
            "pages": [
              "api-manual/image/gpt-image-2",
              "api-manual/image/gpt-image-2-all"
            ]
          },
          {
            "group": "Video Series",
            "icon": "video",
            "pages": [
              "api-manual/video/gemini-omni-t2v",
              "api-manual/video/gemini-omni-i2v",
              "api-manual/video/gemini-omni-r2v",
              "api-manual/video/gemini-omni-extend",
              "api-manual/video/video-ds-2-0",
              "api-manual/video/video-ds-2-0-fast",
              "api-manual/video/veo3-1-lite",
              "api-manual/video/veo3-1-lite-4k",
              "api-manual/video/veo3-1-fast",
              "api-manual/video/veo3-1-fast-4k",
              "api-manual/video/veo3-1-fast-ref",
              "api-manual/video/veo3-1-quality",
              "api-manual/video/veo3-1-quality-4k"
            ]
          },
          {
            "group": "Endpoint Reference",
            "icon": "brackets-curly",
            "pages": [
              "api-reference/chat-completions",
              "api-reference/images",
              "api-reference/video-generation",
              "api-reference/list-models"
            ]
          },
          {
            "group": "Task Management",
            "icon": "list-check",
            "pages": ["api-reference/task-status", "api-reference/webhooks"]
          }
        ]
