{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "FreeModel",
  "description": "FreeModel API documentation for text, image, and video models, integrations, guides, and troubleshooting.",
  "colors": {
    "primary": "#4F46E5",
    "light": "#7C6FF0",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Console",
        "href": "https://freemodel.app/settings"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://freemodel.app/sign-up"
    }
  },
  "navigation": {
    "tabs": [
      {
